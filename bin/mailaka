#!/usr/bin/env node
/**
 * Mailaka Auto-Setup Wrapper
 * Installe automatiquement les dependances au premier lancement
 */

const { spawn, execSync } = require('child_process');
const path = require('path');
const fs = require('fs');
const os = require('os');

const colors = {
  red: '\x1b[31m',
  green: '\x1b[32m',
  blue: '\x1b[34m',
  yellow: '\x1b[33m',
  dim: '\x1b[2m',
  reset: '\x1b[0m'
};

function log(msg, color = 'blue') {
  console.log(`${colors[color]}●${colors.reset} ${msg}`);
}

function warn(msg) {
  console.log(`${colors.yellow}●${colors.reset} ${msg}`);
}

function error(msg) {
  console.error(`${colors.red}●${colors.reset} ${msg}`);
}

function success(msg) {
  console.log(`${colors.green}✔${colors.reset} ${msg}`);
}

function info(msg) {
  console.log(`${colors.dim}  ${msg}${colors.reset}`);
}

// Detection
function getInstallPath() {
  try {
    const npmGlobal = execSync('npm root -g', { encoding: 'utf8' }).trim();
    return path.join(npmGlobal, 'mailaka');
  } catch {
    return path.dirname(path.dirname(__filename));
  }
}

function checkPython() {
  const candidates = ['python3', 'python'];
  for (const cmd of candidates) {
    try {
      const version = execSync(`${cmd} --version`, { encoding: 'utf8', stdio: 'pipe' }).trim();
      return { cmd, version };
    } catch {}
  }
  return null;
}

function checkVenv(baseDir) {
  const venvPath = path.join(baseDir, 'venv');
  return {
    exists: fs.existsSync(venvPath),
    path: venvPath
  };
}

function checkMailakaInstalled(venvPath) {
  const mailakaPath = os.platform() === 'win32'
    ? path.join(venvPath, 'Scripts', 'mailaka.exe')
    : path.join(venvPath, 'bin', 'mailaka');
  return fs.existsSync(mailakaPath);
}

// Auto-setup
function setupEnvironment() {
  console.log(`${colors.blue}═══════════════════════════════════════════════════${colors.reset}`);
  console.log(`${colors.blue}  Mailaka - Premiere configuration${colors.reset}`);
  console.log(`${colors.blue}═══════════════════════════════════════════════════${colors.reset}\n`);
  
  // 1. Verifier Python
  const python = checkPython();
  if (!python) {
    error('Python 3.8+ est requis mais non trouvé.');
    console.log('\nInstallation de Python :');
    console.log('  Ubuntu/Debian:  sudo apt install python3 python3-pip python3-venv');
    console.log('  macOS:          brew install python3');
    console.log('  Windows:        https://python.org/downloads\n');
    process.exit(1);
  }
  log(`Python detecte: ${python.version}`);
  
  // 2. Chemin d'installation
  const baseDir = getInstallPath();
  log(`Installation dans: ${baseDir}`);
  
  if (!fs.existsSync(baseDir)) {
    error(`Repertoire introuvable: ${baseDir}`);
    process.exit(1);
  }
  
  // 3. Creer virtualenv
  const venvPath = path.join(baseDir, 'venv');
  if (!checkVenv(baseDir).exists) {
    log('Creation de l\'environnement Python...');
    info('Cela peut prendre quelques secondes...');
    try {
      execSync(`${python.cmd} -m venv "${venvPath}"`, { stdio: 'pipe' });
      success('Environnement cree');
    } catch (err) {
      error('Echec de la creation de l\'environnement');
      process.exit(1);
    }
  }
  
  // 4. Installer Mailaka
  if (!checkMailakaInstalled(venvPath)) {
    log('Installation des dependances...');
    info('Telechargement et installation de Mailaka...');
    const pip = os.platform() === 'win32'
      ? path.join(venvPath, 'Scripts', 'pip.exe')
      : path.join(venvPath, 'bin', 'pip');
    
    try {
      execSync(`"${pip}" install -e "${baseDir}"`, { stdio: 'inherit' });
      success('Mailaka installe avec succes');
    } catch (err) {
      error('Echec de l\'installation');
      process.exit(1);
    }
  }
  
  console.log(`\n${colors.green}═══════════════════════════════════════════════════${colors.reset}`);
  console.log(`${colors.green}  Configuration terminee!${colors.reset}`);
  console.log(`${colors.green}═══════════════════════════════════════════════════${colors.reset}\n`);
  
  return { baseDir, venvPath };
}

// Run
function runMailaka() {
  const baseDir = getInstallPath();
  const venvPath = path.join(baseDir, 'venv');
  const mailakaPath = os.platform() === 'win32'
    ? path.join(venvPath, 'Scripts', 'mailaka.exe')
    : path.join(venvPath, 'bin', 'mailaka');
  
  const args = process.argv.slice(2);
  
  // Check if first run - auto setup
  if (!fs.existsSync(mailakaPath)) {
    setupEnvironment();
  }
  
  // Run mailaka
  const proc = spawn(mailakaPath, args, { stdio: 'inherit' });
  
  proc.on('error', (err) => {
    if (err.code === 'ENOENT') {
      warn('Mailaka non trouve, tentative de reparation...');
      setupEnvironment();
      console.log('\nRelance...\n');
      runMailaka();
    } else {
      error(`Erreur: ${err.message}`);
      process.exit(1);
    }
  });
  
  proc.on('exit', (code) => {
    if (code && code !== 0 && (code === 127 || code === 9009)) {
      warn('Probleme detecte, reparation automatique...');
      setupEnvironment();
      console.log('\nRelance...\n');
      runMailaka();
      return;
    }
    process.exit(code || 0);
  });
}

// Check if running diagnostics only
if (process.argv.includes('--fix') || process.argv.includes('--repair')) {
  setupEnvironment();
} else {
  runMailaka();
}
